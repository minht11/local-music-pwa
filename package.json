{
	"name": "local-music-pwa-next",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"prepare": "svelte-kit sync",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check",
		"check:i18n": "node scripts/check-translations.ts",
		"biome-check": "biome check ./src",
		"biome-fix": "biome check ./src --write",
		"prettier-check": "prettier --check ./src",
		"prettier-fix": "prettier --write ./src",
		"compile-i18n": "paraglide-js compile --project ./project.inlang",
		"test": "vitest run",
		"coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@inlang/paraglide-js": "2.11.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.51.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0-next.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24.10.13",
		"@vitest/coverage-v8": "^4.0.18",
		"fake-indexeddb": "^6.2.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "5.51.1",
		"svelte-check": "^4.4.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"unplugin-auto-import": "^21.0.0",
		"vite": "8.0.0-beta.14",
		"vite-imagetools": "^9.0.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@material/material-color-utilities": "^0.4.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tanstack/virtual-core": "^3.13.18",
		"@types/dom-navigation": "^1.0.6",
		"@types/wicg-file-system-access": "^2023.10.7",
		"idb": "^8.0.3",
		"music-metadata": "^11.12.0",
		"tiny-invariant": "^1.3.3",
		"weak-lru-cache": "^1.2.2"
	},
	"engines": {
		"node": "24.12.0"
	},
	"packageManager": "pnpm@10.29.3"
}
